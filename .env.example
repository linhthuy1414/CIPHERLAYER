# ─── CipherLayer Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# These are used by the Vite dev server (import.meta.env.VITE_*)
# and exposed to shelby-service.js via the SDK bridge.

# Required for real Shelby uploads/downloads
# Obtain from: https://geomi.dev (create account → API Resource → Testnet → Generate)
# Use a CLIENT key (not server key) for browser usage
VITE_SHELBY_API_KEY=

# Optional — improves Aptos tx confirmation reliability
# Obtain from: https://developers.aptoslabs.com
VITE_APTOS_API_KEY=

# ─── Wallet Funding ──────────────────────────────────────────────────────────
# Before real uploads, fund your wallet with:
#   APT:       https://faucet.testnet.aptoslabs.com/
#   ShelbyUSD: https://docs.shelby.xyz/apis/faucet/shelbyusd
#              or join Discord: https://discord.gg/shelbyprotocol
